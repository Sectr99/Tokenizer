# Cloudflare Pages cache rules
# https://developers.cloudflare.com/pages/configuration/headers/

# Border PNGs — immutable once deployed (content-addressed by filename)
/assets/borders/*
  Cache-Control: public, max-age=31536000, immutable

# JS and CSS — cache aggressively, bust via query string on updates
/js/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

# HTML — always revalidate so users get the latest shell
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Root — same as index.html
/
  Cache-Control: public, max-age=0, must-revalidate
