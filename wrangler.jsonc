{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tokenforge",
  "compatibility_date": "2026-06-15",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "run_worker_first": false
  },
  "build": {
    "command": "npm run build:css"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
